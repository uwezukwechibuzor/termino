{
  "dashboard": {
    "title": "Crypto Streaming System",
    "uid": "crypto-streaming",
    "panels": [
      {
        "title": "Prices Produced (rate)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(prices_produced_total[1m])",
            "legendFormat": "{{symbol}}"
          }
        ]
      },
      {
        "title": "Prices Consumed (rate)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(prices_consumed_total[1m])",
            "legendFormat": "{{symbol}}"
          }
        ]
      },
      {
        "title": "API Latency",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(api_latency_seconds_bucket[5m]))",
            "legendFormat": "p95 {{exchange}}"
          }
        ]
      },
      {
        "title": "Active Streaming Clients",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "streaming_active_clients"
          }
        ]
      },
      {
        "title": "Alerts Triggered",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "sum(alerts_triggered_total)"
          }
        ]
      },
      {
        "title": "DB Rows Inserted",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "rate(db_rows_inserted_total[1m])"
          }
        ]
      },
      {
        "title": "API Errors",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "rate(api_errors_total[1m])",
            "legendFormat": "{{exchange}}"
          }
        ]
      }
    ]
  }
}
