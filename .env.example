# ============================================
# Termino - Crypto Price Streaming System
# Copy this file to .env and adjust values
# ============================================

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PRICES=price-events
KAFKA_TOPIC_AGG=aggregated-prices
KAFKA_TOPIC_ALERTS=price-alerts

# --- PostgreSQL ---
POSTGRES_USER=crypto
POSTGRES_PASSWORD=crypto
POSTGRES_DB=cryptodb
POSTGRES_DSN=postgres://crypto:crypto@localhost:5432/cryptodb?sslmode=disable

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- Price Producer ---
POLL_INTERVAL=5
SYMBOLS=BTC,ETH,SOL,ADA,DOT,AVAX,MATIC,LINK

# --- Streaming API ---
HTTP_PORT=8080

# --- Prometheus Metrics Ports ---
PROMETHEUS_PORT=9090

# --- Logging ---
LOG_LEVEL=info

# --- CLI Client ---
STREAM_URL=http://localhost:8080

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=admin
